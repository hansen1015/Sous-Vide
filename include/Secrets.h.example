#ifndef SECRETS_H_EXAMPLE
#define SECRETS_H_EXAMPLE

// ============================================================================
// SECRETS TEMPLATE FILE
// ============================================================================
// 
// To use this file:
// 1. Copy this file to src/Secrets.h
// 2. Replace the placeholder values with your actual credentials
// 3. NEVER commit src/Secrets.h to version control
//
// ============================================================================

// Telegram Bot Token - Get from BotFather (https://t.me/botfather)
// Replace YOUR_BOT_TOKEN_HERE with your actual bot token
// Format: "123456789:ABCdefGHIjklMNOpqrsTUVwxyz"
#define BOT_TOKEN "YOUR_BOT_TOKEN_HERE"

// ============================================================================
// OTA (Over-The-Air) Update Authentication
// ============================================================================
// Username and password for web-based firmware updates at /update
// IMPORTANT: Change these from the defaults for security!
#define OTA_USERNAME "admin"
#define OTA_PASSWORD "sousvide2024"

// ============================================================================
// WiFi Manager Access Point Credentials
// ============================================================================
// These credentials are used when the device enters configuration mode
// (when it can't connect to a known WiFi network)
// The AP will be named: SousVide_Config_AP
// IMPORTANT: Change the password for security!
#define WIFI_AP_PASSWORD "sousvide123"  // Min 8 characters

// ============================================================================
// SECURITY NOTES:
// ============================================================================
// - Keep your bot token secret - anyone with the token can control your bot
// - If you accidentally commit your token, revoke it immediately via BotFather
// - Change default OTA and AP passwords before deploying to production
// - For production use, consider enabling SSL certificate validation
//   (currently setInsecure() is used for development convenience)
// ============================================================================

#endif
